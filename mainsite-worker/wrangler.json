{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mainsite-app",
  "main": "src/index.js",
  "compatibility_date": "2026-03-14",
  "preview_urls": false,
  "routes": [
    {
      "pattern": "mainsite-app.lcv.rio.br",
      "zone_name": "lcv.rio.br",
      "custom_domain": true
    }
  ],
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bigdata_db",
      "database_id": "6a71b62e-8ab9-45e6-a867-c0d4e6a56269"
    }
  ],
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "mainsite-media"
    }
  ],
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": ["* * * * *"]
  }
}