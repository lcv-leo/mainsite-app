{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mainsite-motor",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-14",
  "preview_urls": false,
  "routes": [
    {
      "pattern": "mainsite-app.lcv.rio.br",
      "zone_name": "lcv.rio.br",
      "custom_domain": true
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bigdata_db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "mainsite-media"
    }
  ],
  "ratelimits": [
    {
      "name": "RL_CHATBOT",
      "namespace_id": "1001",
      "simple": {
        "limit": 5,
        "period": 60
      }
    },
    {
      "name": "RL_EMAIL",
      "namespace_id": "1002",
      "simple": {
        "limit": 3,
        "period": 60
      }
    },
    {
      "name": "GLOBAL_RATE_LIMITER",
      "namespace_id": "1003",
      "simple": {
        "limit": 10,
        "period": 60
      }
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": [
      "*/5 * * * *"
    ]
  },
  "placement": {
    "mode": "smart"
  },
  "secrets_store_secrets": [
    {
      "binding": "CLOUDFLARE_PW",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "cloudflare-pw"
    },
    {
      "binding": "GEMINI_API_KEY",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "gemini-api-key"
    },
    {
      "binding": "RESEND_API_KEY",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "resend-appkey"
    },
    {
      "binding": "MP_ACCESS_TOKEN",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "mp-access-token"
    },
    {
      "binding": "SUMUP_API_KEY_PRIVATE",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "sumup-api-key-private"
    },
    {
      "binding": "SUMUP_MERCHANT_CODE",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "sumup-merchant-code"
    },
    {
      "binding": "CF_AI_GATEWAY",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "cf-ai-gateway"
    },
    {
      "binding": "PIX_KEY",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "PIX_KEY"
    },
    {
      "binding": "PIX_NAME",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "PIX_NAME"
    },
    {
      "binding": "PIX_CITY",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "PIX_CITY"
    }
  ]
}