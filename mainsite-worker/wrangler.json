{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mainsite-motor",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-06",
  "preview_urls": false,
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bigdata_db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "mainsite-media"
    }
  ],
  "ratelimits": [
    {
      "name": "RL_CHATBOT",
      "namespace_id": "1001",
      "simple": {
        "limit": 5,
        "period": 60
      }
    },
    {
      "name": "RL_EMAIL",
      "namespace_id": "1002",
      "simple": {
        "limit": 3,
        "period": 60
      }
    },
    {
      "name": "GLOBAL_RATE_LIMITER",
      "namespace_id": "1003",
      "simple": {
        "limit": 10,
        "period": 60
      }
    },
    {
      "name": "RL_COMMENTS",
      "namespace_id": "1004",
      "simple": {
        "limit": 3,
        "period": 60
      }
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "invocation_logs": true,
      "head_sampling_rate": 1
    }
  },
  "triggers": {
    "crons": [
      "*/5 * * * *"
    ]
  },
  "placement": {
    "mode": "smart"
  },
  "secrets_store_secrets": [
    {
      "binding": "CLOUDFLARE_PW",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "cloudflare-pw"
    },
    {
      "binding": "GEMINI_API_KEY",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "gemini-api-key"
    },
    {
      "binding": "RESEND_API_KEY",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "resend-appkey"
    },
    {
      "binding": "SUMUP_API_KEY_PRIVATE",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "sumup-api-key-private"
    },
    {
      "binding": "SUMUP_MERCHANT_CODE",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "sumup-merchant-code"
    },
    {
      "binding": "PIX_KEY",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "PIX_KEY"
    },
    {
      "binding": "PIX_NAME",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "PIX_NAME"
    },
    {
      "binding": "PIX_CITY",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "PIX_CITY"
    }
  ]
}