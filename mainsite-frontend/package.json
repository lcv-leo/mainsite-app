{
  "name": "mainsite-frontend",
  "private": true,
  "version": "3.6.7",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "node ./scripts/run-vitest.mjs run",
    "test:ui": "node ./scripts/run-vitest.mjs --ui",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "format": "biome format --write src",
    "knip": "knip",
    "stats": "ANALYZE=true vite build",
    "prepare": "husky"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@tanstack/react-query": "^5.100.5",
    "dompurify": "^3.4.1",
    "lucide-react": "^1.11.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tanstack/react-query-devtools": "^5.100.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.0.0",
    "knip": "^6.8.0",
    "lint-staged": "^16.4.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "biome format --write",
      "eslint --fix"
    ]
  },
  "overrides": {
    "picomatch": "4.0.4",
    "undici": "6.24.0",
    "vite": "$vite",
    "serialize-javascript": "^7.0.5",
    "workbox-build": {
      "glob": "13.0.6"
    },
    "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@1.5.5"
  }
}
