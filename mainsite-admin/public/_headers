# Módulo: mainsite-admin/public/_headers
# Descrição: Headers de segurança para o painel admin (sem CSP — acesso restrito via Cloudflare Access).

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=()

/assets/*
  Cache-Control: public, max-age=31536000, immutable
